model Media {
    id                 String             @id @default(cuid())
    title              String             @unique
    mediaType          MediaType          @default(MOVIE)
    synopsis           String
    genres             String[]
    releaseYear        Int
    director           String
    cast               String[]
    platforms          String[]
    pricingType        PricingType        @default(FREE)
    /** Admin-curated list for home “Editor’s picks” */
    editorsPick        Boolean            @default(false)
    purchasePrice      Float?
    rentalPrice        Float?
    rentalDurationDays Int                @default(7)
    streamUrl          String?
    posterUrl          String?
    thumbnailUrl     String?
    averageRating      Float              @default(0)
    reviews            Review[]
    watchlisted        Watchlist[]
    titleEntitlements  TitleEntitlement[]
    createdAt          DateTime           @default(now())
    updatedAt          DateTime           @updatedAt
}
